<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vision.camera.mapper.CameraMapper">

    <resultMap id="BaseResultMap" type="com.vision.camera.entity.Camera">
        <id column="id" property="id" jdbcType="VARCHAR"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="business_line" property="businessLine" jdbcType="VARCHAR"/>
        <result column="location" property="location" jdbcType="VARCHAR"/>
        <result column="stream_url" property="streamUrl" jdbcType="VARCHAR"/>
        <result column="capture_frequency" property="captureFrequency" jdbcType="VARCHAR"/>
        <result column="ai_enabled" property="aiEnabled" jdbcType="BOOLEAN"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="last_capture_time" property="lastCaptureTime" jdbcType="TIMESTAMP"/>
        <result column="source" property="source" jdbcType="VARCHAR"/>
        <result column="platform_id" property="platformId" jdbcType="VARCHAR"/>
        <result column="channel_no" property="channelNo" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- 查询属于指定分组ID列表的摄像头ID -->
    <select id="selectCameraIdsByGroupIds" resultType="java.lang.String">
        SELECT DISTINCT camera_id FROM camera_group_mapping
        WHERE group_id IN
        <foreach collection="groupIds" item="gid" open="(" separator="," close=")">
            #{gid}
        </foreach>
    </select>

</mapper>
